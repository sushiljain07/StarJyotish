# Copy this file to .env and fill in your values
# cp .env.example .env

# OpenRouter API key — preferred way to call Claude (claude-sonnet-4.6).
# If set, this takes priority over ANTHROPIC_API_KEY below.
# Get yours at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# Anthropic API key — used as primary LLM (Reading, Ask, Career Report)
# only if OPENROUTER_API_KEY above is not set.
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Groq API key — fallback LLM, used if neither OPENROUTER_API_KEY nor
# ANTHROPIC_API_KEY is set, or if Claude errors out.
# Free at https://console.groq.com
# Charts, Dasha, KP, and planet tables work without any of these keys
GROQ_API_KEY=gsk_your_key_here

# Optional — shown to OpenRouter for attribution/leaderboard purposes only.
# Safe to leave as-is or omit entirely.
OPENROUTER_SITE_URL=https://starjyotish.app
OPENROUTER_SITE_NAME=Star Jyotish

# Production only — your deployed frontend's origin(s), added to the CORS
# allow-list in main.py (localhost:5173/3000 are already allowed for local
# dev, no need to add them here). Comma-separate multiple origins if needed,
# e.g. when previewing both the production and a Vercel preview domain.
# FRONTEND_URL=https://starjyotish.com

# Postgres connection string for the persistence layer (db/, alembic/).
# Optional — every existing chart/report endpoint works with this unset,
# exactly as it always has (see db/session.py's get_db_optional). Only the
# new routers/account.py endpoints and `python -m db.seed` require it.
# Railway/Heroku-style "postgres://..." URLs are accepted as-is; the app
# rewrites them to "postgresql://..." itself.
#
# Local dev (after `docker run -e POSTGRES_PASSWORD=postgres -p 5432:5432 postgres:16`
# or installing Postgres locally):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/starjyotish_dev
#
# Railway: add a Postgres plugin to the project, then set this to its
# provided DATABASE_URL (Railway exposes it as a reference variable).
# DATABASE_URL=

