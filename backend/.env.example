# Copy this file to .env and fill in your values
# cp .env.example .env

# OpenRouter API key — preferred way to call Claude (claude-sonnet-4.6).
# If set, this takes priority over ANTHROPIC_API_KEY below.
# Get yours at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# Anthropic API key — used as primary LLM (Reading, Ask, Career Report)
# only if OPENROUTER_API_KEY above is not set.
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Groq API key — fallback LLM, used if neither OPENROUTER_API_KEY nor
# ANTHROPIC_API_KEY is set, or if Claude errors out.
# Free at https://console.groq.com
# Charts, Dasha, KP, and planet tables work without any of these keys
GROQ_API_KEY=gsk_your_key_here

# Optional — shown to OpenRouter for attribution/leaderboard purposes only.
# Safe to leave as-is or omit entirely.
OPENROUTER_SITE_URL=https://starjyotish.app
OPENROUTER_SITE_NAME=Star Jyotish

# Production only — your deployed frontend's origin(s), added to the CORS
# allow-list in main.py (localhost:5173/3000 are already allowed for local
# dev, no need to add them here). Comma-separate multiple origins if needed,
# e.g. when previewing both the production and a Vercel preview domain.
# FRONTEND_URL=https://starjyotish.com

# Postgres connection string for the persistence layer (db/, alembic/).
# Optional — every existing chart/report endpoint works with this unset,
# exactly as it always has (see db/session.py's get_db_optional). Only the
# new routers/account.py endpoints and `python -m db.seed` require it.
# Railway/Heroku-style "postgres://..." URLs are accepted as-is; the app
# rewrites them to "postgresql://..." itself.
#
# Local dev (after `docker run -e POSTGRES_PASSWORD=postgres -p 5432:5432 postgres:16`
# or installing Postgres locally):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/starjyotish_dev
#
# Railway: add a Postgres plugin to the project, then set this to its
# provided DATABASE_URL (Railway exposes it as a reference variable).
# DATABASE_URL=

# ── Phone OTP + Google login (backend/routers/auth.py) ──────────────────

# Signs/verifies short-lived access tokens (backend/services/jwt_service.py).
# Required for ANY login endpoint to work. Generate a real value with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# Rotating this invalidates every currently-issued access token (users
# just get a fresh one silently via /api/auth/refresh) but NOT existing
# refresh-token sessions, which aren't JWTs at all — see db/models/session.py.
JWT_SECRET_KEY=

# HMAC key for hashing OTP codes before they're stored (db/repositories/
# otp_repository.py) — a *different* random value than JWT_SECRET_KEY,
# generated the same way. Required for /api/auth/otp/send to work.
OTP_HASH_SECRET=

# Set to "false" for local dev over plain http://localhost. Browsers
# refuse to send a cookie marked Secure over a non-TLS connection, full
# stop — there's no localhost exception for this — so without setting
# this, the refresh-token cookie silently never gets sent back on
# /api/auth/refresh during local development. Leave unset (defaults to
# "true") in any real deployment, which always terminates TLS.
# COOKIE_SECURE=false

# OTP SMS delivery — set EITHER of these (or neither, for local dev: with
# no provider configured, /api/auth/otp/send logs the code to the server
# console instead of sending an SMS, so the whole login flow is testable
# locally with zero SMS spend).
#
# MSG91 (https://msg91.com) — DLT-compliant template-based OTP SMS.
# MSG91_AUTH_KEY=
# MSG91_TEMPLATE_ID=
#
# 2Factor (https://2factor.in) — plain SMS send, used here rather than
# their auto-generated-OTP endpoint so the code in the SMS always matches
# what this backend hashed and stored.
# TWOFACTOR_API_KEY=
#
# If both keys above happen to be set, MSG91 is used by default. Force
# 2Factor instead (e.g. while comparing delivery rates) with:
# OTP_PROVIDER=2factor

# Google OAuth "Web application" Client ID from
# https://console.cloud.google.com/apis/credentials — the same value the
# frontend's VITE_GOOGLE_CLIENT_ID must use. Required for /api/auth/google
# to work; the frontend's "Continue with Google" button still renders
# without it, but Google will reject the resulting sign-in.
# GOOGLE_CLIENT_ID=

