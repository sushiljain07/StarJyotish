# Copy this file to .env and fill in your values
# cp .env.example .env

# Anthropic API key — primary LLM for Reading, Ask, and Career Report
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Groq API key — fallback LLM, used if ANTHROPIC_API_KEY is unset or errors
# Free at https://console.groq.com
# Charts, Dasha, KP, and planet tables work without either key
GROQ_API_KEY=gsk_your_key_here
