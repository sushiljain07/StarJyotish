# Copy this file to .env (local dev) or set these in your Vercel project's
# Environment Variables (production). Vite only exposes vars prefixed
# VITE_ to client code, by design — never put a secret in this file or
# its real .env counterpart, since everything here ships in the JS bundle.

# Backend base URL. Leave unset for local dev — the Vite dev server
# proxies /api -> http://localhost:8000 automatically (see vite.config.js).
# Required in production, e.g.:
# VITE_API_URL=https://your-backend.up.railway.app

# Google OAuth Client ID (the "Web application" OAuth client from
# https://console.cloud.google.com/apis/credentials — NOT the client
# secret; this one is public by design, the GoogleLogin button sends it
# alongside every sign-in attempt and the backend independently verifies
# the resulting token's signature against Google's keys, so exposing the
# client ID itself isn't a credential leak). Required for the "Continue
# with Google" button (components/auth/GoogleLoginButton.jsx) to work —
# without it the button still renders but Google will reject the flow.
# Add both http://localhost and your production origin to "Authorized
# JavaScript origins" on that OAuth client.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Master switch for whether picking a topic on the landing page forces a
# login first (see config/auth.js). Defaults to false (today's fully-open
# flow) if unset — only set this to "true" once you're ready to require
# an account before generating a chart.
# VITE_LOGIN_REQUIRED=true
